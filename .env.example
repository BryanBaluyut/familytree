# Copy to .env for local development with `netlify dev`.
# In production, set these in the Netlify dashboard instead.

# The shared password people type to access the family tree.
FAMILYTREE_PASSWORD=change-me

# A long random string used to sign the session cookie.
# Generate one with: openssl rand -hex 32
FAMILYTREE_SECRET=change-me-to-a-long-random-string
