 export const hasDiffParents = (node) => node.parents.map(prop('type')).filter(unique).length > 1;
-export const byGender = (target) => (_, b) => (b.gender !== target ? -1 : 1);
+// PATCHED (patch-package): the original `(_, b) => b.gender !== target ? -1 : 1`
+// ignores its first argument and never returns 0, so it is not a valid total-order
+// comparator. Array.prototype.sort is then implementation-defined: V8 (Chrome) and
+// SpiderMonkey (Firefox) order the couple differently, which breaks the internal
+// family invariant in Firefox and crashes calcTree at children/arrange (children[-1]).
+// This consistent comparator keeps the target-gender node first (same as V8 produced
+// for the 2-element couples this is always called on) on every engine.
+export const byGender = (target) => (a, b) => (a.gender === b.gender ? 0 : a.gender === target ? -1 : 1);
 export const relToNode = (store) => (rel) => store.getNode(rel.id);
 export const withRelType = (...types) => (item) => types.includes(item.type);
